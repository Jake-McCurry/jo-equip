# Cloudflare Pages cache + security headers.
# Most-specific rules first; the trailing /* block applies to everything else.

# Hashed JS/CSS bundles emitted by Astro — content-addressed, safe forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# PDFs and book covers — large but not hashed; revalidate after 30 days
# so revisions propagate without forcing every visit to redownload.
/books/*.pdf
  Cache-Control: public, max-age=2592000, must-revalidate
/books/covers/*
  Cache-Control: public, max-age=2592000, must-revalidate

# Brand assets — safe to cache for a day.
/favicon.svg
  Cache-Control: public, max-age=86400
/opengraph.jpg
  Cache-Control: public, max-age=86400

# Default for everything else (HTML, sitemap, robots).
# Always revalidate so content changes go live immediately.
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
