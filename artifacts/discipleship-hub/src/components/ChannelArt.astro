---
import { Image } from "astro:assets";
import type { ChannelId } from "@/data/channels";
import churchImg from "@/assets/channels/church.jpg";
import evidenceImg from "@/assets/channels/evidence.jpg";
import growthImg from "@/assets/channels/growth.jpg";

interface Props {
  channel: ChannelId;
  class?: string;
}
const { channel, class: className = "" } = Astro.props;

const imgMap = {
  church: churchImg,
  growth: growthImg,
  evidence: evidenceImg,
};

/* Duotone effect:
 * The parent card sets `background: channel.gradient` (palette B).
 * We render the photo on top, grayscaled and brightened, then
 * mix-blend-mode:multiply blends it INTO the colored gradient — the photo's
 * darker areas darken the gradient while lighter areas let the channel
 * color come through, producing a duotone "tinted photo" look. */
---
<div class={`overflow-hidden ${className}`} style="position:absolute;inset:0;" aria-hidden="true">
  <Image
    src={imgMap[channel]}
    alt=""
    widths={[640, 1024]}
    sizes="(min-width: 1024px) 33vw, 100vw"
    loading="lazy"
    class="w-full h-full object-cover"
    style="position:absolute;inset:0;filter:grayscale(20%) brightness(1.1) contrast(1.05);mix-blend-mode:multiply;opacity:0.85;"
  />
  {/* Soft top-left highlight for depth */}
  <div
    class="pointer-events-none"
    style="position:absolute;inset:0;background:linear-gradient(135deg, rgba(255,255,255,0.12) 0%, transparent 50%, rgba(0,0,0,0.10) 100%);"
  ></div>
</div>
