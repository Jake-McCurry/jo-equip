---
import "@/styles/global.css";
import { Image } from "astro:assets";
import logoSrc from "@/assets/jol-logo-white.png";
import OpenBookMark from "@/components/OpenBookMark.astro";
import { Search as SearchIcon } from "lucide-react";

interface Props {
  title?: string;
  description?: string;
  /** Override the OG/Twitter image. Path relative to site root, e.g. "/opengraph.jpg" */
  image?: string;
}

const {
  title = "JO EQUIP · Ministry Resources Hub",
  description = "A free digital library of practical discipleship tools for pastors and ministry leaders.",
  image = "/opengraph.jpg",
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const join = (p: string) =>
  (baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl) + p;

const navLinks = [
  { name: "Home", path: "/" },
  { name: "Channels", path: "/channels" },
  { name: "Playlists", path: "/playlists" },
  { name: "Books", path: "/books" },
  { name: "Translate", path: "/translate" },
  { name: "More", path: "/more" },
];

// Active-state detection — strip the base prefix from current path first
const rawPath = Astro.url.pathname;
const stripBase = (p: string) => {
  const b = baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl;
  if (b && p.startsWith(b)) return p.slice(b.length) || "/";
  return p;
};
const currentPath = stripBase(rawPath);

function isActive(linkPath: string) {
  return linkPath === "/" ? currentPath === "/" : currentPath.startsWith(linkPath);
}

const navLinksWithActive = navLinks.map(l => ({ ...l, active: isActive(l.path) }));
const year = new Date().getFullYear();

// Canonical URL — always points at the production site, base-prefix-free.
// This is what we want indexed regardless of dev/preview hosts.
const SITE = "https://equip.jesusonline.com";
const canonicalPath = currentPath === "/" ? "/" : currentPath.replace(/\/$/, "");
const canonicalUrl = SITE + canonicalPath;
const absoluteImage = SITE + image;

// GTM container ID — public identifier, safe to commit.
// Gated on PROD so dev/preview builds don't pollute analytics.
const GTM_ID = "GTM-PKJQNCS";
const gtmEnabled = import.meta.env.PROD;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={join("/favicon.svg")} />
    <link rel="apple-touch-icon" href={join("/favicon.svg")} />
    <meta name="theme-color" content="#002f55" />

    {/* Early-connection hints — get DNS+TLS done before scripts request these origins.
        These don't initiate downloads; they just warm the connection so when GTM
        injects its tags, GA4 fires, or YouTube thumbnails load, those requests
        skip ~100–300 ms of handshake latency. */}
    {gtmEnabled && (
      <>
        <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
        <link rel="preconnect" href="https://www.google-analytics.com" crossorigin />
      </>
    )}
    <link rel="dns-prefetch" href="https://i.ytimg.com" />
    <link rel="dns-prefetch" href="https://app.jesusonline.com" />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="JO EQUIP · Ministry Resources Hub" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:alt" content="JO EQUIP — Ministry Resources Hub" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter / X card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <meta name="twitter:image:alt" content="JO EQUIP — Ministry Resources Hub" />

    {/* Per-page additions (e.g. JSON-LD) */}
    <slot name="head" />

    {/* Google Tag Manager — production-only so dev builds don't pollute analytics. */}
    {gtmEnabled && (
      <script is:inline set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${GTM_ID}');`} />
    )}
  </head>
  <body class="min-h-[100dvh] flex flex-col">

    {/* Skip-to-main-content link for keyboard users (visually hidden until focused). */}
    <a href="#main-content" class="skip-to-content">Skip to main content</a>

    {/* GTM noscript fallback */}
    {gtmEnabled && (
      <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM_ID}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
    )}

    {/* Header */}
    <header class="sticky top-0 z-50 w-full" style="background-color:#002f55;border-bottom:1px solid rgba(255,255,255,0.08);">
      <div class="container mx-auto px-4 md:px-6 flex items-center justify-between py-4 md:py-5 relative">

        <a href={join("/")} class="flex items-center gap-3 md:gap-5 hover:opacity-90 transition-opacity">
          {/* fetchpriority=high tells the browser this is the LCP candidate
              and to prioritize it over the in-viewport channel art photos. */}
          <Image src={logoSrc} alt="JesusOnline" widths={[200, 400]} sizes="200px" format="webp" quality={85} class="h-8 md:h-10 w-auto" loading="eager" fetchpriority="high" />
          <span class="hidden sm:block w-px h-9 md:h-11" style="background-color:rgba(255,255,255,0.2);"></span>
          <div class="hidden sm:flex items-center gap-2.5">
            <OpenBookMark size={40} />
            <div class="flex flex-col leading-none">
              <span class="text-white font-semibold text-lg md:text-xl tracking-wide" style='font-family:"Helvetica Neue",Helvetica,Arial,sans-serif;'>
                JO EQUIP
              </span>
              <span class="text-[12px] md:text-[13px] mt-1" style='color:rgba(255,255,255,0.6);font-family:"Helvetica Neue",Helvetica,Arial,sans-serif;letter-spacing:0.05em;'>
                Ministry Resources Hub
              </span>
            </div>
          </div>
          <div class="sm:hidden flex items-center gap-2">
            <OpenBookMark size={32} />
            <span class="text-white font-semibold text-base" style='font-family:"Helvetica Neue",Helvetica,Arial,sans-serif;'>JO EQUIP</span>
          </div>
        </a>

        {/* Desktop Nav */}
        <nav class="hidden lg:flex items-center gap-0.5" aria-label="Primary">
          {navLinksWithActive.map(link => (
            <a
              href={join(link.path)}
              class="relative px-3 py-2 text-sm font-medium transition-colors rounded hover:text-white"
              style={`color:${link.active ? "#ffffff" : "rgba(255,255,255,0.65)"};`}
              aria-current={link.active ? "page" : undefined}
            >
              {link.name}
              {link.active && (
                <span class="absolute -bottom-1 left-3 right-3 h-0.5 rounded-full" style="background-color:#de5b00;"></span>
              )}
            </a>
          ))}
          <a
            href={join("/search")}
            class="ml-2 inline-flex items-center justify-center w-9 h-9 rounded transition-colors hover:bg-white/10"
            style="color:rgba(255,255,255,0.85);"
            aria-label="Search the library"
            title="Search"
          >
            <SearchIcon className="w-4 h-4" />
          </a>
        </nav>

        {/* Mobile: search icon + menu */}
        <div class="lg:hidden flex items-center gap-1">
          <a
            href={join("/search")}
            class="inline-flex items-center justify-center w-10 h-10 rounded transition-colors hover:bg-white/10"
            style="color:rgba(255,255,255,0.85);"
            aria-label="Search the library"
            title="Search"
          >
            <SearchIcon className="w-5 h-5" />
          </a>
          {/* Mobile hamburger — vanilla HTML + tiny inline script (no React shipped). */}
          <button
            id="mobile-nav-trigger"
            type="button"
            class="p-2 text-white"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-nav-panel"
          >
            <svg id="mobile-nav-icon-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
            <svg id="mobile-nav-icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>

      {/* Mobile nav panel — hidden until trigger toggles `data-open`. */}
      <div
        id="mobile-nav-panel"
        role="navigation"
        aria-label="Mobile"
        class="lg:hidden absolute left-0 right-0 top-full w-full py-3 px-4 flex-col gap-1 z-40 hidden data-[open=true]:flex"
        style="background-color:#001f3d;border-top:1px solid rgba(255,255,255,0.1);"
      >
        {navLinksWithActive.map(link => (
          <a
            href={join(link.path)}
            aria-current={link.active ? "page" : undefined}
            class="text-base font-medium py-3 px-3 rounded transition-colors"
            style={`color:${link.active ? "#ffffff" : "rgba(255,255,255,0.8)"};${link.active ? "background-color:rgba(255,255,255,0.08);" : ""}`}
          >
            {link.name}
          </a>
        ))}
      </div>
    </header>

    <script is:inline>
      (function () {
        var trigger = document.getElementById("mobile-nav-trigger");
        var panel = document.getElementById("mobile-nav-panel");
        var iconOpen = document.getElementById("mobile-nav-icon-open");
        var iconClose = document.getElementById("mobile-nav-icon-close");
        if (!trigger || !panel) return;
        var prevOverflow = "";
        function setOpen(open) {
          panel.dataset.open = open ? "true" : "false";
          trigger.setAttribute("aria-expanded", open ? "true" : "false");
          trigger.setAttribute("aria-label", open ? "Close menu" : "Open menu");
          if (iconOpen && iconClose) {
            iconOpen.style.display = open ? "none" : "";
            iconClose.style.display = open ? "" : "none";
          }
          if (open) {
            prevOverflow = document.body.style.overflow;
            document.body.style.overflow = "hidden";
            var firstLink = panel.querySelector("a[href]");
            if (firstLink) firstLink.focus();
          } else {
            document.body.style.overflow = prevOverflow;
          }
        }
        trigger.addEventListener("click", function () {
          setOpen(panel.dataset.open !== "true");
        });
        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && panel.dataset.open === "true") {
            e.preventDefault();
            setOpen(false);
            trigger.focus();
          }
        });
        // Close panel on link click (delegate inside panel).
        panel.addEventListener("click", function (e) {
          var t = e.target;
          while (t && t !== panel) {
            if (t.tagName === "A") { setOpen(false); return; }
            t = t.parentNode;
          }
        });
      })();
    </script>

    <main id="main-content" class="flex-grow">
      <slot />
    </main>

    {/* Footer */}
    <footer class="mt-16 pt-12 pb-8" style="background-color:#002f55;">
      <div class="container mx-auto px-4 md:px-6">
        <div class="flex flex-col md:flex-row justify-between items-start gap-10 pb-10" style="border-bottom:1px solid rgba(255,255,255,0.12);">
          <div class="max-w-xs">
            <div class="flex items-center gap-3 mb-3">
              <OpenBookMark size={32} />
              <Image src={logoSrc} alt="JesusOnline" widths={[150, 300]} sizes="150px" format="webp" quality={85} class="h-6 w-auto" loading="lazy" />
            </div>
            <div class="mb-4">
              <span class="text-xs font-semibold tracking-widest uppercase" style="color:#0083de;">
                JO EQUIP · Ministry Resources Hub
              </span>
            </div>
            <p class="text-sm leading-relaxed mb-3" style="color:rgba(255,255,255,0.75);">
              A free digital library of practical discipleship tools for pastors and leaders for enhanced ministry impact.
            </p>
            <p class="text-xs" style="color:rgba(255,255,255,0.6);">
              equip.jesusonline.com
            </p>
          </div>

          <div class="flex gap-12 text-sm">
            <div class="flex flex-col gap-3">
              <h4 class="font-semibold text-sm" style="color:#ffffff;">Explore</h4>
              <a href={join("/channels")} class="transition-colors hover:text-white" style="color:rgba(255,255,255,0.75);">Channels</a>
              <a href={join("/playlists")} class="transition-colors hover:text-white" style="color:rgba(255,255,255,0.75);">Playlists</a>
              <a href={join("/books")} class="transition-colors hover:text-white" style="color:rgba(255,255,255,0.75);">Books</a>
              <a href={join("/translate")} class="transition-colors hover:text-white" style="color:rgba(255,255,255,0.75);">Translate</a>
            </div>
            <div class="flex flex-col gap-3">
              <h4 class="font-semibold text-sm" style="color:#ffffff;">Organization</h4>
              <a href="https://jesusonlineministries.org" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white" style="color:rgba(255,255,255,0.75);">JesusOnlineMinistries.org</a>
              <a href={join("/about")} class="transition-colors hover:text-white" style="color:rgba(255,255,255,0.75);">About</a>
              <a href={join("/beliefs")} class="transition-colors hover:text-white" style="color:rgba(255,255,255,0.75);">Beliefs</a>
              <a href={join("/newsletter")} class="transition-colors hover:text-white" style="color:rgba(255,255,255,0.75);">Newsletter</a>
              <a href="mailto:equip@jesusonline.com" class="transition-colors hover:text-white" style="color:rgba(255,255,255,0.75);">equip@jesusonline.com</a>
            </div>
          </div>
        </div>

        <div class="mt-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs" style="color:rgba(255,255,255,0.7);">
          <p>&copy; {year} JesusOnline Ministries. All rights reserved.</p>
          <div class="flex gap-5">
            <a href="https://jesusonlineministries.org/privacy-policy/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Privacy Policy</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
