---
import Layout from "@/layouts/Layout.astro";
import { AlertCircle, ArrowRight } from "lucide-react";

const baseUrl = import.meta.env.BASE_URL;
const join = (p: string) =>
  (baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl) + p;
---
<Layout title="Page Not Found · JO EQUIP">
  <div class="container mx-auto px-4 py-24 max-w-xl text-center">
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-full mb-6" style="background-color:rgba(222,91,0,0.1);">
      <AlertCircle className="w-7 h-7" style={{ color: "#de5b00" }} />
    </div>
    <h1 class="text-4xl md:text-5xl mb-3" style="color:#002f55;">Page Not Found</h1>
    <div class="h-0.5 w-12 mx-auto mb-5" style="background-color:#de5b00;"></div>
    <p class="mb-8 text-lg" style="color:var(--color-muted-foreground);">
      Sorry, we couldn't find the page you were looking for. It may have moved or never existed.
    </p>
    <a href={join("/")} class="inline-flex items-center px-6 py-3 font-semibold rounded transition-colors" style="background-color:#0083de;color:#ffffff;">
      Back to Home <ArrowRight className="w-4 h-4 ml-2" />
    </a>
  </div>
</Layout>
