---
import Layout from "@/layouts/Layout.astro";
import { BookOpen, ExternalLink, ArrowRight } from "lucide-react";
import BreadcrumbsLd from "@/components/BreadcrumbsLd.astro";

const baseUrl = import.meta.env.BASE_URL;
const join = (p: string) =>
  (baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl) + p;

/* Core beliefs grouped into themes for easier reading. */
const groups = [
  {
    heading: "God",
    items: [
      "There is one true God, eternally existing in three persons — Father, Son, and Holy Spirit — each possessing equally all the attributes of Deity and the characteristics of personality.",
    ],
  },
  {
    heading: "Jesus Christ",
    items: [
      "Jesus Christ is God, the living Word, who became flesh through His miraculous conception by the Holy Spirit and His virgin birth — perfect Deity and true humanity united in one person forever.",
      "He lived a sinless life and voluntarily atoned for the sins of mankind by dying on the cross as our substitute, satisfying divine justice and accomplishing salvation for all who trust in Him alone.",
      "He rose bodily from the dead, ascended into heaven, and sat down at the right hand of God the Father, where He continually intercedes for His own as the only mediator between God and man.",
      "Jesus Christ is the Head of the Church — His Body — composed of all who have been joined to Him through saving faith.",
      "Jesus Christ will come again to the earth — personally, visibly, and bodily — to consummate history and the eternal plan of God.",
    ],
  },
  {
    heading: "Mankind & Salvation",
    items: [
      "Man was originally created in the image of God. He sinned by disobeying God; that historic fall brought all mankind under divine condemnation, and human nature is now corrupted and unable to please God apart from regeneration by the Holy Spirit.",
      "The salvation of man is wholly a work of God's free grace — not the work, in whole or in part, of human merit, goodness, or religious ceremony. God justifies and imputes His righteousness to those who put their faith in Christ alone.",
      "Every believer born again of the Spirit may be assured of their salvation from the moment they trust Christ. This assurance rests on the witness of the Holy Spirit, who confirms God's testimony in His written Word.",
    ],
  },
  {
    heading: "The Holy Spirit",
    items: [
      "The Holy Spirit has come into the world to reveal and glorify Christ and to apply His saving work — convicting sinners, drawing them to Christ, imparting new life, and continually indwelling and sealing them until the day of redemption.",
      "Every believer is called to live in the power of the indwelling Spirit, walking in obedience and bearing fruit to the glory of God.",
    ],
  },
  {
    heading: "The Church & Eternity",
    items: [
      "God admonishes His people to assemble together regularly for worship, the ordinances, edification through the Scriptures, and mutual encouragement.",
      "At physical death, the believer enters immediately into eternal, conscious fellowship with the Lord, awaiting the resurrection of the body to everlasting glory.",
      "At physical death, the unbeliever enters immediately into eternal, conscious separation from the Lord, awaiting the resurrection of the body to everlasting judgment.",
    ],
  },
  {
    heading: "The Great Commission",
    items: [
      "The Lord Jesus Christ commanded all believers to proclaim the Gospel throughout the world and to disciple men of every nation. Fulfilling that commission requires that all worldly and personal ambitions be subordinated to a total commitment to Him.",
    ],
  },
];
---
<Layout
  title="What We Believe · JO EQUIP"
  description="The Bible is the sole basis of our beliefs. JesusOnline Ministries has adopted the Statement of Faith used by Cru (Campus Crusade for Christ, Int'l)."
>
  <Fragment slot="head">
    <BreadcrumbsLd items={[
      { name: "Home", url: "/" },
      { name: "More", url: "/more" },
      { name: "What We Believe", url: "/beliefs" },
    ]} />
  </Fragment>
  <section class="bg-white">
    <div class="container mx-auto px-4 py-14 md:py-20 max-w-4xl">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color:#0083de;">Statement of Faith</div>
      <h1 class="text-4xl md:text-5xl mb-4" style="color:#002f55;">What We Believe</h1>
      <div class="h-0.5 w-12 mb-7" style="background-color:#de5b00;"></div>
      <p class="text-lg leading-relaxed mb-5" style="color:#374151;">
        JesusOnline Ministries has adopted the Statement of Faith used by
        <strong style="color:#002f55;">Cru (Campus Crusade for Christ, Int'l)</strong>.
      </p>
    </div>
  </section>

  <section class="py-14 md:py-20 border-t" style="background-color:#f4f7fb;border-color:var(--color-border);">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="bg-white border rounded p-7 md:p-10" style="border-color:var(--color-border);border-left:4px solid #0083de;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded flex items-center justify-center" style="background-color:rgba(0,131,222,0.1);">
            <BookOpen className="w-5 h-5" style={{ color: "#0083de" }} />
          </div>
          <h2 class="text-2xl" style="color:#002f55;">The Bible</h2>
        </div>
        <p class="text-base leading-relaxed mb-4" style="color:#374151;">
          The sole basis of our beliefs is the <strong style="color:#002f55;">Bible</strong>, God's infallible
          written Word — the 66 books of the Old and New Testaments. We believe it was uniquely, verbally, and
          fully inspired by the Holy Spirit, and was written without error in the original manuscripts. It is
          the supreme and final authority in all matters on which it speaks.
        </p>
        <p class="text-base leading-relaxed" style="color:#374151;">
          We accept those areas of doctrinal teaching on which, historically, there has been general agreement
          among all true Christians. Because of the specialized calling of our movement, we allow for freedom
          of conviction on other doctrinal matters — provided any interpretation rests upon the Bible alone
          and does not hinder the ministry to which God has called us.
        </p>
      </div>
    </div>
  </section>

  <section class="py-14 md:py-20 bg-white border-t" style="border-color:var(--color-border);">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="mb-10">
        <h2 class="text-3xl md:text-4xl" style="color:#002f55;">Core Beliefs</h2>
        <div class="mt-2 h-0.5 w-12" style="background-color:#de5b00;"></div>
      </div>
      <div class="space-y-8">
        {groups.map(g => (
          <div>
            <h3 class="text-xl mb-3" style="color:#002f55;">{g.heading}</h3>
            <ul class="space-y-3">
              {g.items.map(item => (
                <li class="flex gap-3 text-base leading-relaxed" style="color:#374151;">
                  <span class="shrink-0 mt-2 w-1.5 h-1.5 rounded-full" style="background-color:#de5b00;"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <p class="mt-10 text-sm" style="color:var(--color-muted-foreground);">
        Read the full statement on the
        <a href="https://jesusonlineministries.org/documents/what-we-believe/" target="_blank" rel="noopener noreferrer" class="font-semibold inline-flex items-center gap-1 hover:underline" style="color:#0083de;">
          JesusOnline Ministries site<ExternalLink className="w-3.5 h-3.5" />
        </a>.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-14" style="background-color:#002f55;">
    <div class="container mx-auto px-4 max-w-3xl text-center">
      <h2 class="text-2xl md:text-3xl mb-3" style="color:#ffffff;">Learn more about JesusOnline</h2>
      <p class="text-base mb-6" style="color:rgba(255,255,255,0.85);">
        Our mission, vision, strategy, and history.
      </p>
      <a href={join("/about")} class="inline-flex items-center px-6 py-3 font-semibold rounded transition-colors" style="background-color:#ffffff;color:#0083de;">
        About JesusOnline
        <ArrowRight className="w-4 h-4 ml-2" />
      </a>
    </div>
  </section>
</Layout>
