---
import Layout from "@/layouts/Layout.astro";
import { subTopics, getChannel, getSubTopic, getNextSubTopic } from "@/data/channels";
import { FileText, Video, Smartphone, ArrowLeft, ArrowRight, ChevronRight } from "lucide-react";
import BreadcrumbsLd from "@/components/BreadcrumbsLd.astro";

const baseUrl = import.meta.env.BASE_URL;
const join = (p: string) =>
  (baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl) + p;

export function getStaticPaths() {
  return subTopics.map(s => ({
    params: { channelId: s.channelId, subId: s.id },
  }));
}

const { channelId, subId } = Astro.params;
const channel = getChannel(channelId!);
const sub = getSubTopic(channelId!, subId!);
if (!channel || !sub) return Astro.redirect(join("/channels"));

const next = getNextSubTopic(channelId!, subId!);
const hasItems = (sub.items?.length ?? 0) > 0;

function btnClass(enabled: boolean) {
  return "inline-flex items-center gap-1.5 px-2.5 py-1 rounded text-[11px] font-semibold uppercase tracking-wider transition-all" + (enabled ? " hover:shadow-sm" : " cursor-not-allowed");
}
---
<Layout title={`${sub.name} · ${channel.shortName} · JO EQUIP`} description={`${sub.name} — ${channel.tagline}`}>
  <Fragment slot="head">
    <BreadcrumbsLd items={[
      { name: "Home", url: "/" },
      { name: "Channels", url: "/channels" },
      { name: channel.shortName, url: `/channels/${channel.id}` },
      { name: sub.name, url: `/channels/${channel.id}/${sub.id}` },
    ]} />
  </Fragment>
  {/* Hero */}
  <div class="relative overflow-hidden" style={`background:${channel.gradient};`}>
    <div class="absolute inset-0 pointer-events-none" style="background-image:repeating-linear-gradient(45deg, rgba(255,255,255,0.05) 0, rgba(255,255,255,0.05) 1px, transparent 1px, transparent 18px);"></div>
    <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full pointer-events-none" style="background-color:rgba(255,255,255,0.08);filter:blur(20px);"></div>
    <div class="container mx-auto px-4 py-12 md:py-16 relative max-w-5xl">
      <nav class="flex items-center text-sm mb-6 flex-wrap gap-1" style="color:rgba(255,255,255,0.8);">
        <a href={join("/channels")} class="hover:text-white transition-colors">Channels</a>
        <ChevronRight className="w-3 h-3" />
        <a href={join(`/channels/${channel.id}`)} class="hover:text-white transition-colors">{channel.shortName}</a>
        <ChevronRight className="w-3 h-3" />
        <span style="color:rgba(255,255,255,0.95);">{sub.name}</span>
      </nav>

      <div class="text-xs uppercase tracking-widest font-semibold mb-2" style="color:rgba(255,255,255,0.7);">{channel.name}</div>
      <h1 class="text-3xl md:text-5xl mb-2" style="color:#ffffff;font-weight:500;">{sub.name}</h1>
      <p class="text-sm md:text-base" style="color:rgba(255,255,255,0.8);">PDFs, videos, and JO App resources are linked where available.</p>
    </div>
  </div>

  <div class="container mx-auto px-4 py-12 md:py-16 max-w-5xl">
    <a href={join(`/channels/${channel.id}`)} class="inline-flex items-center text-sm font-medium mb-8 transition-colors hover:text-primary" style="color:var(--color-muted-foreground);">
      <ArrowLeft className="w-4 h-4 mr-2" /> Back to {channel.name}
    </a>

    {hasItems ? (
      <>
        <div class="mb-6 pb-4 border-b" style="border-color:var(--color-border);">
          <h2 class="text-2xl" style="color:#002f55;">Questions Explored</h2>
          <div class="mt-2 h-0.5 w-12" style="background-color:#de5b00;"></div>
        </div>
        <ol class="space-y-2">
          {sub.items!.map(item => {
            // PDF: enabled only when this specific item has a matching book in our library
            // (or an explicit external `links.pdf` override).
            const pdfHref = item.bookId
              ? join(`/books?download=${encodeURIComponent(item.bookId)}#${encodeURIComponent(item.bookId)}`)
              : item.links?.pdf;
            const pdfInternal = !!item.bookId;

            // Video: enabled only when this item has a matching video inside the sub-topic's playlist
            // (or an explicit external `links.video` override). No fallback to the playlist index.
            const videoHref = item.videoId && sub.playlistId
              ? join(`/playlist/${encodeURIComponent(sub.playlistId)}?play=${encodeURIComponent(item.videoId)}`)
              : item.links?.video;
            const videoInternal = !!(item.videoId && sub.playlistId);

            const appHref = item.links?.app;

            const buttons: { label: string; icon: any; href?: string; internal?: boolean }[] = [
              { label: "PDF", icon: FileText, href: pdfHref, internal: pdfInternal },
              { label: "Video", icon: Video, href: videoHref, internal: videoInternal },
              { label: "App", icon: Smartphone, href: appHref, internal: false },
            ];
            return (
              <li class="flex items-start gap-4 p-4 bg-white border rounded hover:shadow-sm transition-all" style="border-color:var(--color-border);">
                <span class="shrink-0 w-9 h-9 rounded-full flex items-center justify-center font-mono font-semibold text-sm" style={`background-color:${channel.accentColor}15;color:${channel.accentColor};`}>
                  {item.number}
                </span>
                <div class="flex-grow min-w-0">
                  <h3 class="text-base leading-snug mb-2.5" style="color:#002f55;">{item.title}</h3>
                  <div class="flex flex-wrap gap-1.5">
                    {buttons.map(b => {
                      const enabled = !!b.href && b.href !== "#";
                      const Icon = b.icon;
                      const enabledStyle = `background-color:${channel.accentColor}15;color:${channel.accentColor};border:1px solid ${channel.accentColor}33;`;
                      const disabledStyle = "background-color:rgba(0,0,0,0.04);color:#9ca3af;border:1px solid rgba(0,0,0,0.06);";
                      if (!enabled) {
                        return (
                          <span class={btnClass(false)} style={disabledStyle} title={`${b.label} coming soon`}>
                            <Icon className="w-3 h-3" />{b.label}
                          </span>
                        );
                      }
                      return b.internal ? (
                        <a href={b.href} class={btnClass(true)} style={enabledStyle}>
                          <Icon className="w-3 h-3" />{b.label}
                        </a>
                      ) : (
                        <a href={b.href} target="_blank" rel="noopener noreferrer" class={btnClass(true)} style={enabledStyle}>
                          <Icon className="w-3 h-3" />{b.label}
                        </a>
                      );
                    })}
                  </div>
                </div>
              </li>
            );
          })}
        </ol>
      </>
    ) : (
      <div class="py-16 text-center border border-dashed rounded bg-white" style="border-color:var(--color-border);">
        <p class="mb-2" style="color:var(--color-muted-foreground);">Resources for this topic are being prepared.</p>
        <p class="text-sm" style="color:var(--color-muted-foreground);opacity:0.7;">Check back soon for books, playlists, and app content.</p>
      </div>
    )}

    {next && (
      <a href={join(`/channels/${channel.id}/${next.id}`)} class="group block mt-12 p-6 md:p-7 rounded border-2 hover:shadow-md transition-all" style={`border-color:${channel.accentColor};background-color:${channel.accentColor}06;`}>
        <div class="flex items-center justify-between gap-4">
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest mb-1" style={`color:${channel.accentColor};`}>Up Next</div>
            <h3 class="text-xl md:text-2xl font-semibold group-hover:underline" style="color:#002f55;">{next.name}</h3>
            <p class="text-sm mt-1" style="color:var(--color-muted-foreground);">Continue exploring {channel.shortName} Resources</p>
          </div>
          <div class="shrink-0 w-12 h-12 rounded-full flex items-center justify-center transition-transform group-hover:translate-x-1" style={`background-color:${channel.accentColor};`}>
            <ArrowRight className="w-5 h-5" style={{ color: "#fff" }} />
          </div>
        </div>
      </a>
    )}
  </div>
</Layout>
