---
import Layout from "@/layouts/Layout.astro";
import ChannelArt from "@/components/ChannelArt.astro";
import { Image } from "astro:assets";
import { channels, getChannel, getSubTopicsByChannel } from "@/data/channels";
import { getBookCover } from "@/data/bookCovers";
import { ArrowRight, MenuSquare, FileText, Video, Smartphone } from "lucide-react";
import BreadcrumbsLd from "@/components/BreadcrumbsLd.astro";

const baseUrl = import.meta.env.BASE_URL;
const join = (p: string) =>
  (baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl) + p;

export function getStaticPaths() {
  return channels.map(c => ({ params: { channelId: c.id } }));
}

const { channelId } = Astro.params;
const channel = getChannel(channelId!);
if (!channel) return Astro.redirect(join("/channels"));

const subs = getSubTopicsByChannel(channel.id);

---
<Layout title={`${channel.name} · JO EQUIP`} description={channel.description}>
  <Fragment slot="head">
    <BreadcrumbsLd items={[
      { name: "Home", url: "/" },
      { name: "Channels", url: "/channels" },
      { name: channel.shortName, url: `/channels/${channel.id}` },
    ]} />
  </Fragment>
  {/* Channel hero */}
  <div class="relative overflow-hidden" style={`background:${channel.gradient};`}>
    <div class="absolute inset-0 opacity-30">
      <ChannelArt channel={channel.id} class="absolute inset-0 w-full h-full" />
    </div>
    <div class="container mx-auto px-4 py-14 md:py-20 relative">
      <a href={join("/channels")} class="inline-flex items-center text-sm font-medium mb-6 transition-colors" style="color:rgba(255,255,255,0.85);">← All Channels</a>
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl" style="color:#ffffff;font-weight:500;">{channel.name}</h1>
      </div>
    </div>
  </div>

  <div class="container mx-auto px-4 py-12 md:py-16">
    <div class="max-w-3xl mb-10">
      <p class="text-lg leading-relaxed mb-2 font-medium" style={`color:${channel.accentColor};`}>{channel.tagline}</p>
      <p class="leading-relaxed" style="color:var(--color-muted-foreground);">{channel.description}</p>
    </div>
    <div class="flex items-center justify-between mb-8 pb-4 border-b" style="border-color:var(--color-border);">
      <div>
        <h2 class="text-2xl" style="color:#002f55;">Topics in this Channel</h2>
        <div class="mt-2 h-0.5 w-12" style="background-color:#de5b00;"></div>
      </div>
      <span class="text-sm" style="color:var(--color-muted-foreground);">{subs.length} topics</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {subs.map((sub, idx) => {
        const coverId = sub.coverId || sub.bookId;
        const cover = coverId ? getBookCover(coverId) : undefined;
        const bookHref = sub.bookId ? join(`/books?download=${encodeURIComponent(sub.bookId)}#${encodeURIComponent(sub.bookId)}`) : undefined;
        const playlistHref = sub.playlistId ? join(`/playlist/${encodeURIComponent(sub.playlistId)}`) : undefined;
        const appHref = sub.appUrl;
        const formats = sub.formats ?? [];
        return (
          <div class="flex flex-col bg-white border rounded overflow-hidden hover:shadow-md transition-all" style={`border-color:var(--color-border);border-left:4px solid ${channel.accentColor};`}>
            <div class="p-5 pb-0">
              <div class="flex items-start justify-between gap-3 mb-3">
                <span class="text-xs font-mono font-semibold px-2 py-0.5 rounded" style={`color:${channel.accentColor};background-color:${channel.accentColor}11;`}>
                  {String(idx + 1).padStart(2, "0")}
                </span>
              </div>
              <h3 class="text-base font-semibold leading-snug mb-4" style="color:#002f55;">{sub.name}</h3>
            </div>

            {cover && (
              <div class="flex justify-center px-5 mb-3">
                <Image src={cover} alt={sub.name} width={160} class="rounded shadow-sm" loading="lazy" />
              </div>
            )}

            {formats.length > 0 && (
              <div class="flex flex-wrap justify-center gap-1.5 px-5 mb-4">
                {formats.includes("book") && (
                  bookHref
                    ? <a href={bookHref} class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider hover:shadow-sm" style="background-color:#de5b0014;color:#de5b00;border:1px solid #de5b0040;" onclick="event.stopPropagation();"><FileText className="w-3 h-3" />Book</a>
                    : <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider cursor-not-allowed" style="background-color:rgba(0,0,0,0.04);color:#9ca3af;border:1px solid rgba(0,0,0,0.06);"><FileText className="w-3 h-3" />Book</span>
                )}
                {formats.includes("playlist") && (
                  playlistHref
                    ? <a href={playlistHref} class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider hover:shadow-sm" style="background-color:#de5b0014;color:#de5b00;border:1px solid #de5b0040;" onclick="event.stopPropagation();"><Video className="w-3 h-3" />Playlist</a>
                    : <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider cursor-not-allowed" style="background-color:rgba(0,0,0,0.04);color:#9ca3af;border:1px solid rgba(0,0,0,0.06);"><Video className="w-3 h-3" />Playlist</span>
                )}
                {formats.includes("app") && (
                  appHref
                    ? <a href={appHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider hover:shadow-sm" style="background-color:#de5b0014;color:#de5b00;border:1px solid #de5b0040;" onclick="event.stopPropagation();"><Smartphone className="w-3 h-3" />App</a>
                    : <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider cursor-not-allowed" style="background-color:rgba(0,0,0,0.04);color:#9ca3af;border:1px solid rgba(0,0,0,0.06);"><Smartphone className="w-3 h-3" />App</span>
                )}
              </div>
            )}

            <a href={join(`/channels/${channel.id}/${sub.id}`)} class="group flex items-center justify-center gap-2 mt-auto mx-5 mb-5 px-4 py-2.5 rounded font-semibold text-sm transition-all" style={`background-color:${channel.accentColor};color:#ffffff;`}>
              <MenuSquare className="w-4 h-4" />
              See Menu
              <ArrowRight className="w-4 h-4 group-hover:translate-x-0.5 transition-transform" />
            </a>
          </div>
        );
      })}
    </div>
  </div>
</Layout>
