---
import Layout from "@/layouts/Layout.astro";
import ChannelArt from "@/components/ChannelArt.astro";
import { channels, getSubTopicsByChannel } from "@/data/channels";
import { ArrowRight } from "lucide-react";

const baseUrl = import.meta.env.BASE_URL;
const join = (p: string) =>
  (baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl) + p;
---
<Layout title="Channels · JO EQUIP">
  <div class="container mx-auto px-4 py-12 md:py-16">
    <div class="max-w-3xl mb-12">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color:#0083de;">Resource Channels</div>
      <h1 class="text-4xl md:text-5xl mb-4" style="color:#002f55;">Three Channels for Your Ministry Needs</h1>
      <div class="h-0.5 w-12 mb-5" style="background-color:#de5b00;"></div>
      <p class="leading-relaxed text-lg" style="color:var(--color-muted-foreground);">
        Carefully selected, free resources grouped to help you serve with greater
        effectiveness and spiritual vitality in fulfilling Christ's Great Commission.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {channels.map(channel => {
        const subCount = getSubTopicsByChannel(channel.id).length;
        return (
          <a href={join(`/channels/${channel.id}`)} class="group flex flex-col bg-white border rounded overflow-hidden hover:shadow-lg transition-all" style="border-color:var(--color-border);">
            <div class="relative aspect-[16/9] overflow-hidden" style={`background:${channel.gradient};`}>
              <ChannelArt channel={channel.id} class="absolute inset-0" />
            </div>
            <div class="p-6 flex flex-col flex-grow" style={`border-top:4px solid ${channel.accentColor};`}>
              <h2 class="text-2xl mb-1 group-hover:text-primary transition-colors" style="color:#002f55;">{channel.name}</h2>
              <p class="text-sm font-medium mb-4" style={`color:${channel.accentColor};`}>{channel.tagline}</p>
              <p class="leading-relaxed text-sm mb-5 flex-grow" style="color:var(--color-muted-foreground);">{channel.description}</p>
              <div class="flex items-center justify-between pt-4 border-t" style="border-color:rgba(229,231,235,0.6);">
                <span class="text-xs font-semibold uppercase tracking-wider px-2 py-1 rounded" style={`color:${channel.accentColor};background-color:${channel.accentColor}11;`}>
                  {subCount} Topics
                </span>
                <span class="inline-flex items-center text-sm font-medium" style={`color:${channel.accentColor};`}>
                  Explore <ArrowRight className="w-4 h-4 ml-1.5" />
                </span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
