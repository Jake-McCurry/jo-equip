---
import Layout from "@/layouts/Layout.astro";
import { Users2, BookOpen, Mail, FileText, ExternalLink, ArrowRight, Send } from "lucide-react";
import BreadcrumbsLd from "@/components/BreadcrumbsLd.astro";

const baseUrl = import.meta.env.BASE_URL;
const join = (p: string) =>
  (baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl) + p;

interface Section {
  title: string;
  icon: any;
  description: string;
  href: string;
  accent: string;
  external?: boolean;
}

const SECTIONS: Section[] = [
  {
    title: "About",
    icon: Users2,
    description: "Learn about JesusOnline Ministries — our mission, vision, strategy, and history.",
    href: "/about",
    accent: "#0083de",
  },
  {
    title: "Statement of Faith",
    icon: BookOpen,
    description: "Our doctrinal convictions and biblical foundations.",
    href: "/beliefs",
    accent: "#002f55",
  },
  {
    title: "Newsletter",
    icon: Send,
    description: "Subscribe to the Make and Multiply Disciples newsletter for updates and new resources.",
    href: "/newsletter",
    accent: "#0083de",
  },
  {
    title: "JO Mobile App",
    icon: ExternalLink,
    description: "Get the JesusOnline app: Growing in Christ, anywhere, anytime.",
    href: "https://app.jesusonline.com",
    accent: "#4c8a4c",
    external: true,
  },
  {
    title: "Privacy Policy",
    icon: FileText,
    description: "How JesusOnline Ministries handles your information.",
    href: "https://jesusonlineministries.org/privacy-policy/",
    accent: "#0083de",
    external: true,
  },
  {
    title: "Contact",
    icon: Mail,
    description: "Email us directly at equip@jesusonline.com with comments or questions.",
    href: "mailto:equip@jesusonline.com",
    accent: "#de5b00",
    external: true,
  },
];
---
<Layout
  title="About and More · JO EQUIP"
  description="About JesusOnline Ministries, our Statement of Faith, the JO Mobile App, privacy policy, and how to contact us."
>
  <Fragment slot="head">
    <BreadcrumbsLd items={[
      { name: "Home", url: "/" },
      { name: "More", url: "/more" },
    ]} />
  </Fragment>
  <div class="container mx-auto px-4 py-12 md:py-16">
    <div class="max-w-3xl mb-12">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color:#0083de;">More</div>
      <h1 class="text-4xl md:text-5xl mb-4" style="color:#002f55;">About and More</h1>
      <div class="h-0.5 w-12 mb-5" style="background-color:#de5b00;"></div>
      <p class="leading-relaxed text-lg" style="color:var(--color-muted-foreground);">
        Information about JesusOnline Ministries, our beliefs, and how to get in touch.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {SECTIONS.map(s => {
        const Icon = s.icon;
        const href = s.external ? s.href : join(s.href);
        return (
          <a
            href={href}
            target={s.external ? "_blank" : undefined}
            rel={s.external ? "noopener noreferrer" : undefined}
            class="group block bg-white border rounded p-6 hover:shadow-md transition-all"
            style={`border-color:var(--color-border);border-left:4px solid ${s.accent};`}
          >
            <div class="flex items-start gap-4 mb-3">
              <div class="w-10 h-10 rounded flex items-center justify-center shrink-0" style={`background-color:${s.accent}15;`}>
                <Icon className="w-5 h-5" style={{ color: s.accent }} />
              </div>
              <h2 class="text-lg pt-1.5 group-hover:text-primary transition-colors" style="color:#002f55;">{s.title}</h2>
            </div>
            <p class="text-sm leading-relaxed mb-4" style="color:var(--color-muted-foreground);">{s.description}</p>
            <span class="inline-flex items-center text-sm font-medium" style={`color:${s.accent};`}>
              {s.external ? (<>Open <ExternalLink className="w-4 h-4 ml-1" /></>) : (<>Open <ArrowRight className="w-4 h-4 ml-1" /></>)}
            </span>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
