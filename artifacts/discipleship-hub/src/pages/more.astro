---
import Layout from "@/layouts/Layout.astro";
import { Users2, BookOpen, Mail, FileText, ExternalLink, ArrowRight } from "lucide-react";

const baseUrl = import.meta.env.BASE_URL;
const join = (p: string) =>
  (baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl) + p;

const SECTIONS = [
  { title: "About", icon: Users2, description: "Learn about JesusOnline Ministries and the EQUIP initiative.", href: "#", accent: "#0083de" },
  { title: "Statement of Faith", icon: BookOpen, description: "Our doctrinal convictions and biblical foundations.", href: "#", accent: "#002f55" },
  { title: "JO Mobile App", icon: ExternalLink, description: "Get the JesusOnline app: Growing in Christ, anywhere, anytime.", href: "https://app.jesusonline.com", accent: "#00855c", external: true },
  { title: "Privacy Policy", icon: FileText, description: "How we handle your information.", href: "#", accent: "#0083de" },
  { title: "Contact", icon: Mail, description: "Reach the EQUIP team for questions or partnership.", href: "#", accent: "#de5b00" },
];
---
<Layout title="About and More · JO EQUIP">
  <div class="container mx-auto px-4 py-12 md:py-16">
    <div class="max-w-3xl mb-12">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color:#0083de;">More</div>
      <h1 class="text-4xl md:text-5xl mb-4" style="color:#002f55;">About and More</h1>
      <div class="h-0.5 w-12 mb-5" style="background-color:#de5b00;"></div>
      <p class="leading-relaxed text-lg" style="color:var(--color-muted-foreground);">
        Information about JesusOnline Ministries, our beliefs, and how to get in touch.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {SECTIONS.map(s => {
        const Icon = s.icon;
        const href = s.external ? s.href : join(s.href);
        return (
          <a
            href={href}
            target={s.external ? "_blank" : undefined}
            rel={s.external ? "noopener noreferrer" : undefined}
            class="group block bg-white border rounded p-6 hover:shadow-md transition-all"
            style={`border-color:var(--color-border);border-left:4px solid ${s.accent};`}
          >
            <div class="flex items-start gap-4 mb-3">
              <div class="w-10 h-10 rounded flex items-center justify-center shrink-0" style={`background-color:${s.accent}15;`}>
                <Icon className="w-5 h-5" style={{ color: s.accent }} />
              </div>
              <h2 class="text-lg pt-1.5 group-hover:text-primary transition-colors" style="color:#002f55;">{s.title}</h2>
            </div>
            <p class="text-sm leading-relaxed mb-4" style="color:var(--color-muted-foreground);">{s.description}</p>
            <span class="inline-flex items-center text-sm font-medium" style={`color:${s.accent};`}>
              Open <ArrowRight className="w-4 h-4 ml-1" />
            </span>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
