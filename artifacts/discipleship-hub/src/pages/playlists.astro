---
import Layout from "@/layouts/Layout.astro";
import { ListVideo, Play } from "lucide-react";
import { playlists, playlistThumbnail } from "@/data/playlists";

const baseUrl = import.meta.env.BASE_URL;
const join = (p: string) =>
  (baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl) + p;
---
<Layout title="Playlists · JO EQUIP">
  <div class="container mx-auto px-4 py-12 md:py-16">
    <div class="max-w-3xl mb-12">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-9 h-9 rounded flex items-center justify-center" style="background-color:rgba(0,131,222,0.1);">
          <ListVideo className="w-5 h-5" style={{ color: "#0083de" }} />
        </div>
        <span class="text-xs font-semibold tracking-widest uppercase" style="color:#0083de;">Video Library</span>
      </div>
      <h1 class="text-4xl md:text-5xl mb-4" style="color:#002f55;">Playlists</h1>
      <div class="h-0.5 w-12 mb-5" style="background-color:#de5b00;"></div>
      <p class="leading-relaxed text-lg" style="color:var(--color-muted-foreground);">
        Tap a playlist to watch the videos.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {playlists.map(p => {
        const thumb = playlistThumbnail(p);
        const count = p.videos.length;
        const href = join(`/playlist/${p.id}`);
        return (
          <a
            href={href}
            class="group block focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 rounded"
            style="--tw-ring-color:#0083de;"
          >
            {/* Stacked-cards visual: two slivers peeking above the thumbnail */}
            <div class="relative pt-[8px]">
              <span
                class="absolute top-0 left-6 right-6 h-[4px] rounded-t-sm transition-transform duration-200 group-hover:-translate-y-[2px]"
                style="background-color:rgba(0,47,85,0.18);"
                aria-hidden="true"
              ></span>
              <span
                class="absolute top-[4px] left-3 right-3 h-[4px] rounded-t-sm transition-transform duration-200 group-hover:-translate-y-[1px]"
                style="background-color:rgba(0,47,85,0.32);"
                aria-hidden="true"
              ></span>

              <div class="bg-white border rounded overflow-hidden transition-shadow group-hover:shadow-md" style="border-color:var(--color-border);">
                <div class="relative aspect-video bg-slate-100 overflow-hidden">
                  {thumb ? (
                    <img
                      src={thumb}
                      alt={p.title}
                      loading="lazy"
                      width="320"
                      height="180"
                      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <ListVideo className="w-10 h-10" style={{ color: "#94a3b8" }} />
                    </div>
                  )}
                  <div class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/15 transition-colors">
                    <div class="w-14 h-14 rounded-full flex items-center justify-center transition-all duration-200 scale-90 opacity-0 group-hover:opacity-100 group-hover:scale-100" style="background-color:rgba(255,255,255,0.95);">
                      <Play className="w-6 h-6 ml-0.5" style={{ color: "#de5b00", fill: "#de5b00" }} />
                    </div>
                  </div>
                  <div
                    class="absolute bottom-2 right-2 px-2 py-1 rounded text-xs font-semibold flex items-center gap-1"
                    style="background-color:rgba(0,0,0,0.75);color:#ffffff;"
                  >
                    <ListVideo className="w-3 h-3" />
                    {count} {count === 1 ? "video" : "videos"}
                  </div>
                </div>
                <div class="p-4">
                  <h3 class="font-semibold text-base leading-snug mb-1 group-hover:underline" style='color:#002f55;font-family:"Helvetica Neue",Helvetica,Arial,sans-serif;'>
                    {p.title}
                  </h3>
                  <p class="text-sm" style="color:var(--color-muted-foreground);">View full playlist</p>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
