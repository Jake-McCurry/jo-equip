---
import Layout from "@/layouts/Layout.astro";
import { Languages, Globe, Chrome, Smartphone, ExternalLink } from "lucide-react";
import BreadcrumbsLd from "@/components/BreadcrumbsLd.astro";
---
<Layout
  title="Translate · JO EQUIP"
  description="Read JO EQUIP in your heart language. Step-by-step instructions for translating the site with Google Translate on Chrome, Safari, Android, and any browser."
>
  <Fragment slot="head">
    <BreadcrumbsLd items={[
      { name: "Home", url: "/" },
      { name: "Translate", url: "/translate" },
    ]} />
  </Fragment>
  <div class="container mx-auto px-4 py-12 md:py-16 max-w-4xl">
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-9 h-9 rounded flex items-center justify-center" style="background-color:rgba(0,131,222,0.1);">
          <Languages className="w-5 h-5" style={{ color: "#0083de" }} />
        </div>
        <span class="text-xs font-semibold tracking-widest uppercase" style="color:#0083de;">Multilingual Access</span>
      </div>
      <h1 class="text-4xl md:text-5xl mb-4" style="color:#002f55;">Translate this Page</h1>
      <div class="h-0.5 w-12 mb-5" style="background-color:#de5b00;"></div>
      <p class="leading-relaxed text-lg" style="color:var(--color-muted-foreground);">
        Use Google Translate to read JO EQUIP in your heart language. Pick the option that matches the device or
        browser you're using right now.
      </p>
    </div>

    {/* Method 1: Chrome desktop */}
    <div class="bg-white border rounded p-6 md:p-8 mb-5" style="border-color:var(--color-border);">
      <div class="flex items-center gap-3 mb-5 pb-4 border-b" style="border-color:var(--color-border);">
        <Chrome className="w-6 h-6" style={{ color: "#0083de" }} />
        <h2 class="text-xl font-semibold" style="color:#002f55;">Google Chrome (desktop)</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-4">
          <span class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-mono font-semibold mt-0.5" style="background-color:rgba(0,131,222,0.1);color:#0083de;">1</span>
          <div>
            <h4 class="text-base font-semibold mb-1" style="color:#002f55;">Right-click anywhere on the page</h4>
            <div class="leading-relaxed text-sm" style="color:var(--color-muted-foreground);">A menu will appear.</div>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-mono font-semibold mt-0.5" style="background-color:rgba(0,131,222,0.1);color:#0083de;">2</span>
          <div>
            <h4 class="text-base font-semibold mb-1" style="color:#002f55;">Choose "Translate to [your language]"</h4>
            <div class="leading-relaxed text-sm" style="color:var(--color-muted-foreground);">Chrome translates the entire page instantly using Google Translate.</div>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-mono font-semibold mt-0.5" style="background-color:rgba(0,131,222,0.1);color:#0083de;">3</span>
          <div>
            <h4 class="text-base font-semibold mb-1" style="color:#002f55;">Switch language if needed</h4>
            <div class="leading-relaxed text-sm" style="color:var(--color-muted-foreground);">Click the small Google Translate icon in the address bar, then choose another target language.</div>
          </div>
        </li>
      </ol>
    </div>

    {/* Method 2: Mobile */}
    <div class="bg-white border rounded p-6 md:p-8 mb-5" style="border-color:var(--color-border);">
      <div class="flex items-center gap-3 mb-5 pb-4 border-b" style="border-color:var(--color-border);">
        <Smartphone className="w-6 h-6" style={{ color: "#0083de" }} />
        <h2 class="text-xl font-semibold" style="color:#002f55;">Mobile (Chrome / Safari)</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-4">
          <span class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-mono font-semibold mt-0.5" style="background-color:rgba(0,131,222,0.1);color:#0083de;">1</span>
          <div>
            <h4 class="text-base font-semibold mb-1" style="color:#002f55;">Chrome on Android</h4>
            <div class="leading-relaxed text-sm" style="color:var(--color-muted-foreground);">Tap the three-dot menu (⋮) at the top right, then tap <strong>Translate…</strong> and pick your language.</div>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-mono font-semibold mt-0.5" style="background-color:rgba(0,131,222,0.1);color:#0083de;">2</span>
          <div>
            <h4 class="text-base font-semibold mb-1" style="color:#002f55;">Safari on iPhone or iPad</h4>
            <div class="leading-relaxed text-sm" style="color:var(--color-muted-foreground);">Tap the <strong>aA</strong> icon on the left of the address bar, then tap <strong>Translate to [language]</strong>. (You may need to enable translation in Settings → Safari → Translate the first time.)</div>
          </div>
        </li>
      </ol>
    </div>

    {/* Method 3: Manual */}
    <div class="bg-white border rounded p-6 md:p-8 mb-8" style="border-color:var(--color-border);">
      <div class="flex items-center gap-3 mb-5 pb-4 border-b" style="border-color:var(--color-border);">
        <Globe className="w-6 h-6" style={{ color: "#0083de" }} />
        <h2 class="text-xl font-semibold" style="color:#002f55;">Any browser — use Google Translate directly</h2>
      </div>
      <ol class="space-y-5 mb-5">
        <li class="flex gap-4">
          <span class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-mono font-semibold mt-0.5" style="background-color:rgba(0,131,222,0.1);color:#0083de;">1</span>
          <div>
            <h4 class="text-base font-semibold mb-1" style="color:#002f55;">Open translate.google.com</h4>
            <div class="leading-relaxed text-sm" style="color:var(--color-muted-foreground);">
              <a href="https://translate.google.com/?sl=en&tl=es&op=websites" target="_blank" rel="noopener noreferrer" class="inline-flex items-center font-medium hover:underline" style="color:#0083de;">
                Open Google Translate (Websites)
                <ExternalLink className="w-3.5 h-3.5 ml-1" />
              </a>
            </div>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-mono font-semibold mt-0.5" style="background-color:rgba(0,131,222,0.1);color:#0083de;">2</span>
          <div>
            <h4 class="text-base font-semibold mb-1" style="color:#002f55;">Choose "Websites"</h4>
            <div class="leading-relaxed text-sm" style="color:var(--color-muted-foreground);">On the Google Translate site, click the <strong>Websites</strong> tab.</div>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-mono font-semibold mt-0.5" style="background-color:rgba(0,131,222,0.1);color:#0083de;">3</span>
          <div>
            <h4 class="text-base font-semibold mb-1" style="color:#002f55;">Paste this address</h4>
            <div class="leading-relaxed text-sm" style="color:var(--color-muted-foreground);">
              <code class="inline-block mt-1 px-2 py-1 text-xs rounded" style="background-color:rgba(0,47,85,0.06);color:#002f55;">https://equip.jesusonline.com</code>
              <br />Pick your target language and click the arrow.
            </div>
          </div>
        </li>
      </ol>
    </div>

    <div class="p-5 rounded text-sm" style="background-color:rgba(0,131,222,0.06);border-left:4px solid #0083de;color:#002f55;">
      <strong>Heads up:</strong> Google Translate is a third-party machine translation. Theological terms may not always
      translate perfectly. For high-fidelity translations in 40+ languages, also visit
      <a href="https://jesusonline.com" target="_blank" rel="noopener noreferrer" class="underline font-medium">jesusonline.com</a>.
    </div>
  </div>
</Layout>
